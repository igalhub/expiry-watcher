# Expiry Watcher — target configuration template
# Copy this file to config/targets.yaml and fill in real values.
# config/targets.yaml is gitignored and must never be committed.

tls_endpoints:
  - host: "example.com"
    port: 443
  - host: "another-example.com"
    port: 443

local_certs:
  - path: "/path/to/your/cert.pem"
  - path: "/path/to/another/cert.crt"

vault:
  # URL only — not a secret. Credentials go in config/vault.yaml (see vault.yaml.example).
  url: "http://localhost:8200"

settings:
  # How often the checker runs, in hours. Must match the systemd timer interval.
  check_interval_hours: 6
  # Path to the SQLite results database.
  db_path: "results.db"
